# --- Panopticon Geospatial — configuration serveur ---

# Port du proxy Express (backend)
PORT=8787

# Token Cesium ion (optionnel). Non requis : le fond de carte est Mapbox.
# https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# Fond de carte Mapbox. IMPORTANT : Cesium peint le globe avec des tuiles RASTER
# (API Static Tiles), qui ne sait PAS rasteriser les styles "Standard" v3
# (ceux avec `imports`, ex. mapbox/standard-satellite) → tuiles vides.
# Utiliser un style CLASSIQUE raster : satellite-streets-v12, satellite-v9,
# dark-v11, streets-v12, light-v11, outdoors-v12...
VITE_MAPBOX_TOKEN=
VITE_MAPBOX_USER=mapbox
VITE_MAPBOX_STYLE_ID=satellite-streets-v12

# Clé Windy Webcams API v3 (optionnelle) pour la couche CCTV.
# https://api.windy.com/webcams
WINDY_API_KEY=

# OpenSky (trafic aérien). Le quota ANONYME (~400 crédits/jour) sature vite.
# Recommandé : API client OAuth2 (compte OpenSky > Account > API clients) →
# fournit un client_id et un client_secret. Quota bien supérieur.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# (Déprécié) Ancienne authentification Basic, encore acceptée en repli :
OPENSKY_USER=
OPENSKY_PASS=
