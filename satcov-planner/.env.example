# --- SatCov Planner — configuration ---
# Token Cesium ion (optionnel). Non requis : fond de carte Mapbox raster.
VITE_CESIUM_ION_TOKEN=

# Fond Mapbox raster (style CLASSIQUE, pas "Standard" v3). Un token de démo
# est intégré ; surchargez-le pour la production.
# IMPORTANT : utiliser un style RASTER classique (satellite-streets-v12,
# satellite-v9, dark-v11…). Les styles "Standard" v3 (avec `imports`) ne sont
# PAS rasterisables par Cesium → tuiles vides.
VITE_MAPBOX_TOKEN=
VITE_MAPBOX_USER=mapbox
VITE_MAPBOX_STYLE_ID=satellite-streets-v12
